{
  "name": "aoe4-hud",
  "version": "1.2.0",
  "description": "AoE4 overlay HUD (Electron + Vue3)",
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "node scripts/ensure-electron-entry.cjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "vue": "^3.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^35.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.3"
  },
  "private": true,
  "build": {
    "appId": "com.aoe4hud.app",
    "productName": "AoE4 HUD",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
